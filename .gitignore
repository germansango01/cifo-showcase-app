# ============================================================
# Laravel .gitignore
# ============================================================

# --- Dependencias ---
/vendor/
/node_modules/

# --- Variables de entorno ---
.env
.env.*
!.env.example

# --- Compilados y caché de la aplicación ---
/bootstrap/cache/*.php
/storage/*.key
/storage/app/public/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*

# --- Frontend build ---
/public/build/
/public/hot
/public/storage

# --- Testing ---
.phpunit.result.cache
coverage/
/report/

# --- PHP CS Fixer ---
.php-cs-fixer.cache
.php_cs.cache

# --- PHP Stan / Psalm ---
/.phpstan-cache/
/psalm-cache/

# --- IDEs y editores ---
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- NPM / Yarn ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Docker (si aplica) ---
.docker/
docker-compose.override.yml

# --- Backups y temporales ---
*.bak
*.tmp
*.log